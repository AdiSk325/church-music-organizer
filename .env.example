# Environment variables for Church Music Organizer

# Database URL (SQLite by default)
DATABASE_URL=sqlite:///church_music.db

# Upload directory
UPLOAD_DIR=data/uploads

# Processed files directory
PROCESSED_DIR=data/processed

# --- LLM pipeline (Google Gemini via google-genai) -------------------------------
# Paste your Google AI Studio key here (starts with "AIza..."). The google-genai SDK
# is zero-config and picks this up automatically. Make a copy of this file named ".env".
GEMINI_API_KEY=AIzaSy...your_key_here...

# Optional model overrides (defaults shown). CMO_LLM_MODEL is the global default;
# the per-step vars override it for individual pipeline steps.
# CMO_LLM_MODEL=gemini-2.5-flash
# CMO_LLM_MODEL_TEXT=gemini-2.5-flash
# CMO_LLM_MODEL_SCORE=gemini-2.5-flash
# CMO_LLM_MODEL_LYRICS=gemini-2.5-flash
